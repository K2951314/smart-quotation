# ============================================================
# 智能询价系统 .gitignore
# 严格遵循：仓库中不得出现任何客户/公司敏感信息、
# 本地凭据、个人开发笔记、测试 fixtures、临时产物。
# ============================================================

# ─── 操作系统产物 ─────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/
*.lnk

# ─── 编辑器 / IDE ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.fleet/
.history/

# ─── Node 生态 ────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── 构建产物 ─────────────────────────────────────────────
dist/
build/
out/
*.tmp
*.cache
*.log
bundle-report.html

# ─── Python 缓存与虚拟环境 ────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/
env/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ─── 数据库与运行时数据（含客户数据，严格禁止入库）─────────
*.db
*.db-journal
*.sqlite
*.sqlite3
quotation.db
data/
*.db.bak

# ─── 密钥与机密配置（不得入库）────────────────────────────
.env
.env.*
!.env.example
secrets.json
token.txt
*.key
*.pem
*.p12
*.pfx
config.ini
config.local.json
config.production.json
admin-config.local.json

# ─── 原始业务数据 / 大文件（含客户价格表）──────────────────
*.ods
*.xlsx
*.xls
*.csv
!tests/**/*.csv
!config.example.json

# ─── 视频 / 媒体产物 ──────────────────────────────────────
remotion-videos/
*.mp4
*.mov
*.avi
*.mkv

# ─── AI 辅助工具与本地工作记录（私密，不入库）─────────────
.codebuddy/
.claude/
.workbuddy/
.gstack/
.codex/
.aider*
.cursor/
.continue/
.copilot/
.catpaw/

# ─── 本地开发临时 HTML 产物（由构建脚本生成）──────────────
智能询价系统.html
company.html
standalone.html

# ─── 测试覆盖率与临时冒烟测试 ───────────────────────────
coverage/
.nyc_output/
_smoke_test.py
smoke_test.py

# ─── 归档目录（历史快照，不入库）──────────────────────────
_archive/
archive/
*.bak
*.old

# ─── 交付物 / 安全审计 / 内部报告（私密，不入库）──────────
deliverables/
reports/
audit/
*.audit.md

# ─── 构建脚本（用户可选保留；默认不入库以减少暴露面）──────
build_standalone.py

# ─── 其它本地杂项 ─────────────────────────────────────────
*.local
*.local.json
sandbox/
scratch/
tmp/

# ─── 本地操作指南（不入库，每次自己看）────────────────
_LOCAL-GUIDE.md
_local-guide.md
_local-*.md
_DEPLOYMENT-STEPS.md
_DEPLOYMENT-*.md
_deployment-*.md

# ─── CatPaw / Superpowers 工具产物（IDE 特定，不入库）──────
docs/superpowers/
docs/catpaw-*.md
docs/admin-ui-optimization-*.md
