# ============================================================
# 智能询价系统 — 环境变量示例
# 复制为 .env 并填入真实值；.env 已在 .gitignore 中排除，不会入库。
# ============================================================

# ⚠️ 上线前必须轮换所有密钥（ADMIN_API_KEY / STOCK_QUERY_KEY /
#    SQ_LICENSE_SECRET / MMC 凭据 / Supabase service key）。
#    本地开发用的密钥不得直接用于生产——一旦开发机被入侵即全部泄露。
#    生成强密钥：python -c "import secrets; print(secrets.token_urlsafe(32))"

# ─── Admin 后台 API Key（保护 admin 端点）──────────────────
# 客户端访问 /api/configs、/api/items 等管理端点时需在
# Authorization: Bearer <ADMIN_API_KEY> 中携带此值。
# 必须设置，且至少 16 字符；未设置时后端拒绝启动（除非 SQ_DEV=1）。
ADMIN_API_KEY=change-me-to-a-long-random-string

# ─── 本地开发模式开关 ─────────────────────────────────
# 设为 1 时跳过 ADMIN_API_KEY 强校验（用弱默认值）、跳过 ALLOW_ORIGINS 强校验。
# 仅限本地开发，生产环境绝不设置。
SQ_DEV=

# ─── 三菱库存查询专用 Key（生产环境必须设置）──────────────────
# 前端调用 /api/stock-query 时在 X-Stock-Key 请求头携带。
# 安全策略：必须设置为不同于 ADMIN_API_KEY 的值！
# 如果未设置，生产环境下库存查询端点返回 503（拒绝服务）。
# 本地开发（SQ_DEV=1）时可留空，自动回退到 ADMIN_API_KEY。
STOCK_QUERY_KEY=

# ─── 库存查询日配额（可选）──────────────────────────────
# 每个 company_id 每天最多查询次数（24h 滚动窗口）。
# 默认 500 次/天/公司；可根据实际业务量调整。
STOCK_QUERY_DAILY_LIMIT=500

# ─── 三菱库存查询凭据（仅部署在服务端，绝不暴露到前端）─────────
# 从三菱官网 https://mcweb.mitsubishi-materials.com 获取
MMC_USERNAME=
MMC_PASSWORD=
MMC_COOKIE=

# ─── Supabase Storage（数据源 + DB 备份）──────────────────
# SQ_SUPABASE_BASE_URL：前端公开桶地址（config.json / bundles），
#   由 admin 配置中心写入 config.json，也可在此预填默认值。
# SQ_SUPABASE_PROJECT_URL：Supabase 项目根地址（https://<project-ref>.supabase.co），
#   仅用于后端访问 private bucket 的 Storage API；不能填写公开桶地址。
# SQ_SUPABASE_SERVICE_KEY：service role key（仅后端，用于 DB 备份上传/下载）。
#   ⚠️ 必须用 service role key，不能用 anon key——SQLite 含公司令牌等敏感数据。
#   service role key 只能放在后端环境变量，绝不能暴露给前端。
SQ_SUPABASE_BASE_URL=
SQ_SUPABASE_PROJECT_URL=
SQ_SUPABASE_SERVICE_KEY=

# ─── DB 备份配置（Railway 免费版无持久化 Volume 时使用）──────
# 启动时从 Supabase 下载备份，admin 写操作后按需上传（事件驱动+防抖+每日上限）。
# DB_BACKUP_BUCKET：Supabase Storage bucket 名（必须为 private bucket）
# DB_BACKUP_PATH：bucket 内的对象路径
DB_BACKUP_BUCKET=sq-db-backup
DB_BACKUP_PATH=quotation.db

# ─── 生产后端 API 地址（可选，前端通过 window.SQ_PROD_API_BASE 注入）─
# Netlify 独立部署时通过 Snippet injection 注入到 <head>：
#   <script>window.SQ_PROD_API_BASE = "https://your-backend.railway.app";</script>
# ⚠️ ?api= URL 参数仅在本地开发生效（防生产环境 API 劫持）
SQ_PROD_API_BASE=

# ─── CORS 允许的来源（逗号分隔）─────────────────────────
# 生产环境必须设置为你的前端域名；未设 SQ_DEV 时强制要求设置。
ALLOW_ORIGINS=https://your-netlify-site.netlify.app

# ─── 错误监控（Sentry，可选）─────────────────────────
# 设置后后端会自动初始化 Sentry SDK（需 pip install sentry-sdk[fastapi]）。
# 前端通过 window.SQ_SENTRY_DSN 注入 DSN。
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=smart-quotation@0.2.0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── License 授权机制 ───────────────────────────────
# 用 generate_license() 给客户签发 license，客户把它设为 SQ_LICENSE。
# 签名密钥必须设置（至少 16 字符），用于 HMAC-SHA256 验签。
# 本地开发可设 SQ_DEV=1 跳过（使用内置开发密钥）。
# 签发示例：
#   py -c "from backend.smart_quotation.license import generate_license; print(generate_license('客户名', '2027-12-31T23:59:59Z', max_companies=5, features=['core','multi_tenant','stock_query'], secret='你的密钥'))"
SQ_LICENSE_SECRET=
SQ_LICENSE=

# ─── 服务监听（Railway/Render 会自动注入 PORT）──────────────
HOST=0.0.0.0
PORT=8001
